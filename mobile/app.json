{
  "expo": {
    "name": "NXQ Social",
    "slug": "nxq-social-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nxqsocial",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gionyortiz.nxqsocial",
      "buildNumber": "5",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "NXQ Social uses the camera so you can capture photos and videos for your posts, reels, stories, and profile picture.",
        "NSMicrophoneUsageDescription": "NXQ Social uses the microphone to record audio for the videos and reels you create.",
        "NSPhotoLibraryUsageDescription": "NXQ Social needs access to your photo library so you can upload photos and videos to your posts, reels, stories, and profile.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSExceptionDomains": {
            "api.nxqsocial.com": {
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSExceptionMinimumTLSVersion": "TLSv1.2",
              "NSIncludesSubdomains": true
            },
            "nxqsocial.com": {
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSExceptionMinimumTLSVersion": "TLSv1.2",
              "NSIncludesSubdomains": true
            }
          }
        }
      }
    },
    "android": {
      "package": "com.gionyortiz.nxqsocial",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#1e1b4b",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0b1020"
        }
      ],
      "expo-notifications",
      "expo-video",
      "expo-font",
      "@config-plugins/react-native-webrtc"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a4f27391-f0b4-4b73-9a2d-a1f87f68c77c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a4f27391-f0b4-4b73-9a2d-a1f87f68c77c"
    }
  }
}
