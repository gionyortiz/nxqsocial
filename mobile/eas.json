{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.nxqsocial.com/api",
        "EXPO_PUBLIC_USE_RN_FETCH": "false",
        "EXPO_PUBLIC_SHOW_LOGIN_DEBUG": "false"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.nxqsocial.com/api",
        "EXPO_PUBLIC_USE_RN_FETCH": "false",
        "EXPO_PUBLIC_SHOW_LOGIN_DEBUG": "false"
      }
    },
    "compiletest": {
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.nxqsocial.com/api",
        "EXPO_PUBLIC_USE_RN_FETCH": "false",
        "EXPO_PUBLIC_LIVE_NATIVE_ENABLED": "false",
        "EXPO_PUBLIC_SHOW_LOGIN_DEBUG": "false"
      }
    },
    "livetest": {
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.nxqsocial.com/api",
        "EXPO_PUBLIC_USE_RN_FETCH": "false",
        "EXPO_PUBLIC_LIVE_NATIVE_ENABLED": "true",
        "EXPO_PUBLIC_SHOW_LOGIN_DEBUG": "false"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.nxqsocial.com/api",
        "EXPO_PUBLIC_USE_RN_FETCH": "false",
        "EXPO_PUBLIC_LIVE_NATIVE_ENABLED": "false",
        "EXPO_PUBLIC_SHOW_LOGIN_DEBUG": "false"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6775623679",
        "appleTeamId": "5J49RDX477"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
