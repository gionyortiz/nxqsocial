// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// Core user + profile
// ─────────────────────────────────────────
model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  phone              String?            @unique
  username           String             @unique
  passwordHash       String
  role               UserRole           @default(USER)
  verificationStatus VerificationStatus @default(BASIC)
  trustScore         Int                @default(10)
  emailVerified      Boolean            @default(false)
  phoneVerified      Boolean            @default(false)
  emailNotifications Boolean            @default(true)
  isSuspended        Boolean            @default(false)
  isBanned           Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  profile         Profile?
  posts           Post[]
  likes           Like[]
  saves           Save[]
  comments        Comment[]
  followers       Follow[]       @relation("following")
  following       Follow[]       @relation("follower")
  reportsGiven    Report[]       @relation("reporter")
  reportsReceived Report[]       @relation("reported")
  verifications   Verification[]
  feedPref        FeedPreference?
  otpCodes        OtpCode[]
  auditLogs       AuditLog[]     @relation("auditAdmin")
  mediaAssets     MediaAsset[]
  passwordResets  PasswordResetToken[]
  blocking        Block[]        @relation("blocker")
  blockedBy       Block[]        @relation("blocked")
  liveSessions    LiveSession[]  @relation("liveHost")
  analyticsEvents AnalyticsEvent[]
  betaFeedbacks   BetaFeedback[]
  notifications      Notification[] @relation("notificationRecipient")
  notificationsActed Notification[] @relation("notificationActor")
  conversationParticipants ConversationParticipant[]
  sentMessages             DirectMessage[] @relation("directMessageSender")
}

model Block {
  id            String   @id @default(cuid())
  blockerId     String
  blockedId     String
  createdAt     DateTime @default(now())

  blocker User @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Profile {
  id          String  @id @default(cuid())
  userId      String  @unique
  displayName String
  bio         String?
  avatarUrl   String?
  bannerUrl   String?
  location    String?
  website     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// Posts + media
// ─────────────────────────────────────────
model Post {
  id         String     @id @default(cuid())
  authorId   String
  caption    String?
  type       PostType   @default(PHOTO)
  visibility Visibility @default(PUBLIC)
  status     PostStatus @default(PUBLISHED)
  aiLabel    AiLabel    @default(NONE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  author   User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  media    MediaAsset[]
  likes    Like[]
  saves    Save[]
  comments Comment[]
  reports  Report[]
}

model MediaAsset {
  id               String           @id @default(cuid())
  userId           String
  postId           String?
  s3Key            String           @unique
  bucket           String
  url              String?
  thumbnailUrl     String?
  mimeType         String
  size             Int
  width            Int?
  height           Int?
  durationSec      Int?
  c2paStatus       String?
  uploadStatus     UploadStatus     @default(PENDING)
  moderationStatus ModerationStatus @default(PENDING)
  safetyJobId      String?
  safetyResult     Json?
  order            Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post? @relation(fields: [postId], references: [id], onDelete: SetNull)
}

// ─────────────────────────────────────────
// Engagement
// ─────────────────────────────────────────
model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Save {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Conversation {
  id            String                    @id @default(cuid())
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  lastMessageAt DateTime                  @default(now())

  participants ConversationParticipant[]
  messages     DirectMessage[]

  @@index([lastMessageAt])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  createdAt      DateTime     @default(now())
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model DirectMessage {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime     @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("directMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// ─────────────────────────────────────────
// Trust & verification
// ─────────────────────────────────────────
model Verification {
  id          String             @id @default(cuid())
  userId      String
  provider    String
  providerRef String
  level       VerificationStatus
  status      String             @default("pending")
  ageBand     String?
  country     String?
  verifiedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// Moderation
// ─────────────────────────────────────────
model Report {
  id          String       @id @default(cuid())
  reporterId  String
  reportedId  String?
  postId      String?
  reason      ReportReason
  description String?
  status      ReportStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  reporter User  @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User? @relation("reported", fields: [reportedId], references: [id], onDelete: SetNull)
  post     Post? @relation(fields: [postId], references: [id], onDelete: SetNull)
}

// ─────────────────────────────────────────
// Feed preferences
// ─────────────────────────────────────────
model FeedPreference {
  id       String   @id @default(cuid())
  userId   String   @unique
  feedMode FeedMode @default(FOR_YOU)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// OTP verification codes
// ─────────────────────────────────────────
model OtpCode {
  id        String   @id @default(cuid())
  userId    String
  channel   String   // "email" | "phone"
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// Audit log
// ─────────────────────────────────────────
model AuditLog {
  id           String   @id @default(cuid())
  adminId      String
  actionType   String
  targetUserId String?
  targetPostId String?
  reason       String?
  meta         Json?
  createdAt    DateTime @default(now())

  admin User @relation("auditAdmin", fields: [adminId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// Safety flags (scam / link detection)
// ─────────────────────────────────────────
model SafetyFlag {
  id         String   @id @default(cuid())
  entityType String   // "post" | "comment" | "message"
  entityId   String
  flagType   String   // "phishing" | "crypto_scam" | "spam_link" | "suspicious_url" | "fake_giveaway"
  detail     String?
  resolvedAt DateTime?
  createdAt  DateTime @default(now())
}

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────
enum UserRole {
  USER
  CREATOR
  BUSINESS
  MODERATOR
  ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  BASIC
  HUMAN_VERIFIED
  ID_VERIFIED
  BUSINESS_VERIFIED
}

enum PostType {
  PHOTO
  VIDEO
  SHORT_VIDEO
  TEXT
}

enum Visibility {
  PUBLIC
  FOLLOWERS
  PRIVATE
}

enum PostStatus {
  DRAFT
  PUBLISHED
  UNDER_REVIEW
  REMOVED
}

enum AiLabel {
  NONE
  AI_GENERATED
  AI_EDITED
  VERIFIED_CAMERA_SOURCE
  SOURCE_UNKNOWN
}

enum ModerationStatus {
  PENDING
  APPROVED
  FLAGGED
  REJECTED
  REMOVED
}

enum UploadStatus {
  PENDING
  SCANNING
  PUBLISHED
  REJECTED
}

enum ReportReason {
  SPAM
  SCAM
  FAKE_ACCOUNT
  HARASSMENT
  HATE_SPEECH
  VIOLENCE
  NUDITY
  MISINFORMATION
  DEEPFAKE
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  ACTION_TAKEN
  DISMISSED
}

enum FeedMode {
  FOLLOWING
  FOR_YOU
  VERIFIED_HUMANS
  LEARNING
  LOCAL
  FAMILY_SAFE
}

// ─────────────────────────
// Live streaming (Beta)
// ─────────────────────────
model LiveSession {
  id          String     @id @default(cuid())
  room        String     @unique
  hostId      String
  title       String?
  status      LiveStatus @default(LIVE)
  viewerCount Int        @default(0)
  peakViewers Int        @default(0)
  startedAt   DateTime   @default(now())
  endedAt     DateTime?
  updatedAt   DateTime   @updatedAt

  host User @relation("liveHost", fields: [hostId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([hostId])
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  name       String
  userId     String?
  sessionId  String?
  properties Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([name, createdAt])
  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
}

model BetaFeedback {
  id            String               @id @default(cuid())
  userId        String
  type          BetaFeedbackType
  severity      BetaFeedbackSeverity
  route         String
  deviceType    BetaDeviceType
  browser       String
  description   String
  screenshotUrl String?
  status        BetaFeedbackStatus   @default(OPEN)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([severity, createdAt])
  @@index([type, createdAt])
  @@index([userId, createdAt])
}

enum LiveStatus {
  LIVE
  ENDED
}

enum BetaFeedbackType {
  BUG
  UI_PROBLEM
  UPLOAD_PROBLEM
  CALL_PROBLEM
  LIVE_PROBLEM
  VERIFICATION_PROBLEM
  SUGGESTION
}

enum BetaFeedbackSeverity {
  LOW
  MEDIUM
  HIGH
  BLOCKING
}

enum BetaDeviceType {
  MOBILE
  DESKTOP
  TABLET
}

enum BetaFeedbackStatus {
  OPEN
  TRIAGED
  IN_PROGRESS
  RESOLVED
  WONT_FIX
}

// ─────────────────────────────────────────
// In-app notifications
// ─────────────────────────────────────────
model Notification {
  id          String           @id @default(cuid())
  recipientId String
  actorId     String?
  type        NotificationType
  postId      String?
  commentId   String?
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  recipient User  @relation("notificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User? @relation("notificationActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([recipientId, read, createdAt])
  @@index([recipientId, createdAt])
}

enum NotificationType {
  FOLLOW
  LIKE
  COMMENT
  MENTION
}


