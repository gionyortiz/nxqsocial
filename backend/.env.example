# ─────────────────────────────────────────────────────────────────────────────
# NXQ Social Backend — Environment Variables
# Copy this file to .env and fill in all values before running in production.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:STRONG_PASSWORD@localhost:5432/nxqsocial"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_64_BYTE_HEX_SECRET"
JWT_EXPIRES_IN="7d"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://:REDIS_PASSWORD@localhost:6379"

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV="production"
# Comma-separated list of allowed frontend origins (no trailing slash)
# Comma-separated list of allowed frontend origins (no trailing slash)
FRONTEND_URL="https://nxqsocial.com,https://www.nxqsocial.com"
APP_BASE_URL="https://nxqsocial.com"

# ── Private Beta (optional) ───────────────────────────────────────────────────
# Set this to require an invite code at registration. Leave blank for open signups.
# BETA_INVITE_CODE="your-secret-invite-code"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="NXQ Social <noreply@nxqsocial.com>"

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_FROM_NUMBER="+1XXXXXXXXXX"

# ── Storage (choose ONE option) ───────────────────────────────────────────────

# Option A: Cloudflare R2
# S3_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
# S3_BUCKET="nxqsocial-media"
# S3_PUBLIC_BASE_URL="https://media.nxqsocial.com"
# AWS_ACCESS_KEY_ID="R2_ACCESS_KEY"
# AWS_SECRET_ACCESS_KEY="R2_SECRET_KEY"
# AWS_REGION="auto"

# Option B: AWS S3
# S3_BUCKET_NAME="nxqsocial-media"
# S3_PUBLIC_BASE_URL="https://nxqsocial-media.s3.amazonaws.com"
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."
# AWS_REGION="us-east-1"

# ── AWS Rekognition (media safety scanning) ───────────────────────────────────
# Uses the same AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_REGION above.
# The IAM user needs rekognition:DetectModerationLabels and
# rekognition:StartContentModeration permissions.

# ── Admin seed credentials (used by: npx prisma db seed) ─────────────────────
ADMIN_EMAIL="admin@nxqsocial.com"
ADMIN_USERNAME="nxqadmin"
ADMIN_PASSWORD="REPLACE_WITH_STRONG_PASSWORD"
